# OpenAI 兼容 API 配置
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.deepseek.com
MODEL_ID=deepseek-chat

# 可选：搜索 API（DuckDuckGo 免费，无需配置）
# SEARCH_API_KEY=

# ───────────────────────────────────────────────
# 可调参数（不填则使用括号内默认值，见 config.py）
# ───────────────────────────────────────────────

# LLM 调用
# LLM_MAX_RETRIES=3        # OpenAI client 内置重试次数
# LLM_TIMEOUT=120          # client 单次请求超时（秒）
# LLM_MAX_ATTEMPTS=3       # 连接失败时外层手动重试次数
# LLM_MAX_TOKENS=4096      # 单次回复最大 token

# Agent 循环
# AGENT_MAX_TURNS=50       # 父 agent 单次运行最大轮数
# SUBAGENT_MAX_TURNS=30    # 子 agent 最大轮数
# SUBAGENT_CONCURRENCY=3   # parallel_tasks 最大并发 subagent 数

# python_execute 代码执行
# PYEXEC_DEFAULT_TIMEOUT=300   # 默认超时（秒）
# PYEXEC_MAX_TIMEOUT=1800      # 允许的最大超时（秒）

# 上下文压缩
# CONTEXT_LIMIT=60000          # 触发摘要压缩的上下文阈值
# KEEP_RECENT_TOOLS=4          # 压缩时保留最近的工具输出数
# PERSIST_THRESHOLD=20000      # 单条工具输出落盘阈值
# MAX_MESSAGES=60              # 裁剪时保留的最大消息数
# COMPACT_SUMMARY_TOKENS=2000  # 常规压缩摘要 token
# REACTIVE_SUMMARY_TOKENS=1500 # 紧急压缩摘要 token
